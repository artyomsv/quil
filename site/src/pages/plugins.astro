---
/**
 * Plugins — built-in pane types + TOML authoring sample.
 *
 * Data flows from `data/plugins.ts`:
 *   - `plugins[]`: four built-ins displayed as feature cells
 *   - `samplePluginToml`: reference webhook plugin shown verbatim
 *   - `pluginAuthoringRef`: external link to docs/plugin-reference.md
 */
import Page from "@/layouts/Page.astro";
import { SITE } from "@/data/seo";
import { breadcrumbSchema, itemListSchema } from "@/data/schemas";
import { plugins, samplePluginToml, pluginAuthoringRef } from "@/data/plugins";

const seo = {
  title: "Plugins — typed panes with context-aware behaviour",
  description:
    "Quil ships four built-in pane types: Terminal, Claude Code, SSH, and Stripe CLI. Each has its own spawn command, resume strategy, error handler, and status line. Write your own in a single TOML file.",
  path: "/plugins",
  ogImage: "/og/plugins.png",
  keywords: [
    "quil plugins",
    "quil pane types",
    "toml plugin",
    "claude code plugin",
    "ssh pane",
    "webhook pane",
  ],
};

const schemas = [
  breadcrumbSchema([
    { name: "Quil",    path: "/" },
    { name: "Plugins", path: "/plugins" },
  ]),
  itemListSchema({
    name: "Quil built-in plugins",
    description:
      "Four built-in typed pane types — Terminal, Claude Code, SSH, and Stripe CLI — plus an authoring guide for writing your own in TOML.",
    url: SITE.url + "/plugins",
    items: plugins.map((p) => ({
      name: p.name,
      description: p.description,
      url: SITE.url + "/plugins#" + p.slug,
    })),
  }),
];

const tagByKind: Record<PluginEntry["kind"], string> = {
  "built-in":  "← BUILT-IN",
  community:   "← COMMUNITY",
};

type PluginEntry = (typeof plugins)[number];
---
<Page {...seo} schemas={schemas}>
  <section class="page-hero">
    <div class="container-ember stack">
      <div class="hero-ruler">
        <span>§ PLUGINS</span>
        <span>BUILT-IN <b>{plugins.length}</b></span>
        <span>FORMAT <b>TOML</b></span>
        <span style="margin-left:auto;">hot-reload on save</span>
      </div>
      <span class="eyebrow">PANE TYPES · TOML · HOT RELOAD</span>
      <h1>Plugins, in 30 lines of TOML.</h1>
      <p>
        A pane type is a TOML file. No compile. No restart. No shell
        scripting footguns. Drop it in <code>~/.quil/plugins/</code>
        and the daemon reloads on save.
      </p>
    </div>
  </section>

  <section style="padding: 60px 0; border-bottom: 1px solid var(--line);">
    <div class="container-ember stack">
      <span class="eyebrow">BUILT-IN · {plugins.length} TYPES</span>
      <div class="feature-grid" style="margin-top:28px;">
        {plugins.map((plugin, idx) => (
          <div class="feature-cell" id={plugin.slug}>
            <div class="feat-head">
              <span class="feat-num">◇ {String(idx + 1).padStart(2, "0")}</span>
              <span class="feat-title">{plugin.name.toLowerCase()}</span>
            </div>
            <p class="feat-body">{plugin.description}</p>
            <span class="feat-tag">{tagByKind[plugin.kind]}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section style="padding: 80px 0;">
    <div class="container-ember stack">
      <span class="eyebrow">WRITE YOUR OWN · SAMPLE</span>
      <h2 class="h2" style="margin-top:10px; font-size:36px;">A webhook plugin, top to bottom.</h2>
      <p style="margin-top:18px; max-width:60ch; color:var(--ink-2);">
        Drop this in <code>~/.quil/plugins/webhook.toml</code>. Reload
        happens on save — you'll see the new pane type in the
        <code>Ctrl+N</code> dialog seconds later.
      </p>

      <pre style="margin-top:24px; padding:24px; background:#050302; border:1px solid var(--line-2); font-family:var(--mono-stack); font-size:13px; color:var(--ink); overflow-x:auto; line-height:1.55;"><code>{samplePluginToml}</code></pre>

      <p style="margin-top:24px; color:var(--ink-3); font-family:var(--mono-stack); font-size:13px;">
        └── full reference:
        <a href={pluginAuthoringRef} rel="noopener external" style="color:var(--flame);">
          docs/plugin-reference.md
        </a>
      </p>
    </div>
  </section>

  <section class="cta" style="padding: 80px 0;">
    <div class="container-ember stack">
      <div class="cta-inner">
        <h2 style="font-size: clamp(32px, 4.5vw, 52px);">
          Write one. <span class="flame-text">Reload on save.</span>
        </h2>
        <div class="actions">
          <a href="/install" class="btn btn-primary">▸ install quil</a>
          <a href={pluginAuthoringRef} class="btn btn-outline" rel="noopener external">plugin reference →</a>
        </div>
      </div>
    </div>
  </section>
</Page>
