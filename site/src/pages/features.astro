---
/**
 * Features — the full catalogue.
 *
 * Content is sourced from `data/features.ts`; this file only handles
 * layout + SEO. The page auto-keeps up with the data layer — add a
 * new entry with a valid category and it shows up in the right
 * section with no markup edits.
 */
import Page from "@/layouts/Page.astro";
import { SITE } from "@/data/seo";
import { breadcrumbSchema, itemListSchema } from "@/data/schemas";
import { features, featureCategories, type Feature } from "@/data/features";

const seo = {
  title: "Features — typed panes, AI resume, plugin system, and more",
  description:
    "A complete tour of every Quil capability: reboot-proof persistence, typed panes, AI session auto-resume, MCP server, TOML plugin system, notification center, and pane notes.",
  path: "/features",
  ogImage: "/og/features.png",
  keywords: [
    "quil features",
    "terminal multiplexer features",
    "persistent terminal",
    "tmux alternative features",
    "ai session resume",
  ],
};

const schemas = [
  breadcrumbSchema([
    { name: "Quil",     path: "/" },
    { name: "Features", path: "/features" },
  ]),
  itemListSchema({
    name: "Quil features",
    description: `The complete list of Quil capabilities in v${SITE.software.version}: persistence, AI integration, interaction, extensibility, and observability.`,
    url: SITE.url + "/features",
    items: features.map((f) => ({
      name: f.title,
      description: f.blurb,
      url: SITE.url + "/features#" + f.slug,
    })),
  }),
];

const categoryOrder: Feature["category"][] = [
  "persistence",
  "ai",
  "interaction",
  "extensibility",
  "observability",
];

const byCategory: Record<Feature["category"], Feature[]> = {
  persistence:   [],
  ai:            [],
  interaction:   [],
  extensibility: [],
  observability: [],
};
for (const feature of features) {
  byCategory[feature.category].push(feature);
}
---
<Page {...seo} schemas={schemas}>
  <section class="page-hero">
    <div class="container-ember stack">
      <div class="hero-ruler">
        <span>§ FEATURES · {features.length} CAPABILITIES</span>
        <span>CAT <b>{categoryOrder.length}</b></span>
        <span style="margin-left:auto;">scroll for the full catalog ↓</span>
      </div>
      <span class="eyebrow">THE FULL CATALOG</span>
      <h1>Every capability. No fluff.</h1>
      <p>
        {features.length} features across {categoryOrder.length} categories. Each one earns
        its place, each one is load-bearing in a real developer's day.
        If you came here looking for a matrix of checkboxes — this is
        the matrix.
      </p>
    </div>
  </section>

  {categoryOrder.map((cat, index) => {
    const items = byCategory[cat];
    if (items.length === 0) return null;
    const sectionNo = String(index + 1).padStart(2, "0");
    return (
      <section class="feat-category">
        <div class="container-ember stack">
          <div class="feat-category-head">
            <div>
              <span class="eyebrow">§ {sectionNo} / {String(categoryOrder.length).padStart(2, "0")}</span>
              <h2 style="margin-top:10px;">{featureCategories[cat]}</h2>
            </div>
            <span class="count">{items.length} {items.length === 1 ? "FEATURE" : "FEATURES"}</span>
          </div>

          <div class="feat-list">
            {items.map((feature, featureIdx) => (
              <div class="feat-item" id={feature.slug}>
                <span class="idx">[{sectionNo}.{String(featureIdx + 1).padStart(2, "0")}]</span>
                <div>
                  <h3>{feature.title}</h3>
                  <p class="blurb">{feature.blurb}</p>
                  <ul>
                    {feature.detail.map((bullet) => (
                      <li>{bullet}</li>
                    ))}
                  </ul>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    );
  })}

  <section class="cta" style="padding: 80px 0;">
    <div class="container-ember stack">
      <div class="cta-inner">
        <h2 style="font-size: clamp(32px, 4.5vw, 56px);">Ready?</h2>
        <p>
          No account, no signup, no telemetry. <code style="color:var(--flame);">curl | sh</code>
          and you're in.
        </p>
        <div class="actions">
          <a href="/install" class="btn btn-primary">▸ install quil</a>
          <a href="/" class="btn btn-outline">← back home</a>
        </div>
      </div>
    </div>
  </section>
</Page>
