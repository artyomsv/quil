---
/**
 * 404 — rendered via `src/pages/404.astro`. GitHub Pages serves
 * `/404.html` automatically for unmatched paths.
 */
import Page from "@/layouts/Page.astro";

const seo = {
  title: "Page not found",
  description:
    "That workspace wasn't persisted. Head back to quil.cc to find what you were looking for.",
  path: "/404",
};
---
<Page {...seo}>
  <section style="padding: 120px 0 140px;">
    <div class="container-ember stack">
      <div class="cta-inner" style="max-width:720px;">
        <div class="hero-ruler" style="justify-content:center;">
          <span>§ 404 · NOT FOUND</span>
          <span>REV <b>────</b></span>
          <span>GHOST-BUF <b>empty</b></span>
        </div>

        <pre class="cta-ascii" aria-hidden="true" style="margin-top:32px;">
    ┌────────────────────────────────────────────┐
    │                                            │
    │          ▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓          │
    │          ▓    PANE NOT RESTORED    ▓          │
    │          ▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓          │
    │                                            │
    └────────────────────────────────────────────┘
        </pre>

        <h2 style="font-size: clamp(32px, 5vw, 60px); margin-top:8px;">
          That workspace <span class="flame-text">wasn't persisted.</span>
        </h2>

        <p>
          The page you're looking for isn't in the workspace tree.
          Maybe it was never checked in, or maybe a pane split changed
          its path.
        </p>

        <div class="actions">
          <a href="/" class="btn btn-primary">▸ back to home</a>
          <a href="/install" class="btn btn-outline">install quil</a>
        </div>
      </div>
    </div>
  </section>
</Page>
