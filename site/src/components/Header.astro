---
/**
 * Site header — sticky top nav with brand, primary links, compare
 * dropdown, version chip, and GitHub CTA.
 *
 * Zero JS: the compare dropdown uses the native <details>/<summary>
 * element, which gives click-to-open, Escape-to-close, and mobile
 * collapse without a single line of JavaScript.
 *
 * Styling lives in src/styles/ember.css under the `.site-header`
 * scope — keeping class names terse here (the CSS is specific enough
 * that utility overrides aren't needed).
 */
import { SITE } from "@/data/seo";

const navLinks = [
  { href: "/features", label: "features" },
  { href: "/plugins",  label: "plugins"  },
  { href: "/install",  label: "install"  },
  { href: "/docs",     label: "docs"     },
];

const compareLinks = [
  { href: "/vs/tmux",    label: "vs tmux"       },
  { href: "/vs/zellij",  label: "vs Zellij"     },
  { href: "/vs/wezterm", label: "vs WezTerm"    },
  { href: "/vs/screen",  label: "vs GNU Screen" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(href + "/");
}

const compareOpen = compareLinks.some((link) => isActive(link.href));
---
<header class="site-header">
  <nav class="nav" aria-label="Main">
    <a href="/" class="brand">
      <img src="/brand/mark.svg" alt="" aria-hidden="true" width="24" height="26" />
      <span>quil</span>
    </a>

    <ul class="nav-links">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={["nav-link", { active: isActive(link.href) }]}
          >
            {link.label}
          </a>
        </li>
      ))}

      <li>
        <details class="nav-dd" open={compareOpen || undefined}>
          <summary>
            compare <span class="slash">▾</span>
          </summary>
          <ul class="dd-menu">
            {compareLinks.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
          </ul>
        </details>
      </li>
    </ul>

    <div class="nav-right">
      <span class="version-chip">v<b>{SITE.software.version}</b> · {SITE.software.license}</span>
      <a href={SITE.github} class="btn btn-ghost" rel="noopener external">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 0 0 7.86 10.92c.57.1.78-.25.78-.55v-1.92c-3.2.7-3.88-1.54-3.88-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.04-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.56-.3-5.25-1.28-5.25-5.7 0-1.26.45-2.3 1.19-3.1-.12-.3-.52-1.48.11-3.1 0 0 .97-.3 3.18 1.18a11.1 11.1 0 0 1 5.8 0c2.2-1.48 3.17-1.18 3.17-1.18.63 1.62.23 2.8.12 3.1.74.8 1.19 1.84 1.19 3.1 0 4.43-2.7 5.4-5.27 5.68.42.36.78 1.07.78 2.16v3.2c0 .3.2.66.78.55A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
        </svg>
        github
      </a>
    </div>
  </nav>
</header>
