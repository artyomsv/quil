---
// Shared template for every /vs/<competitor>/ page. Each competitor
// page is a thin stub that imports this component and passes its slug:
//
//   import ComparePage from "@/components/ComparePage.astro";
//   <ComparePage slug="tmux" />
//
// All content (matrix rows, positioning paragraph, FAQ) comes from
// src/data/competitors.ts — one edit there updates all four pages.

import Page from "@/layouts/Page.astro";
import Icon from "@/components/Icon.astro";
import {
  competitorMatrix,
  competitors,
  type CompetitorInfo,
  type Support,
} from "@/data/competitors";
import { breadcrumbSchema, faqSchema } from "@/data/schemas";

interface Props {
  slug: CompetitorInfo["slug"];
}

const { slug } = Astro.props;
const info = competitors[slug];

const seo = {
  title: `Quil vs ${info.name}`,
  description: `How Quil compares to ${info.name}: side-by-side feature matrix, where each tool wins, and what ${info.name} can't do that Quil can. Reboot-proof persistence, AI session resume, typed panes, MCP server.`,
  path: `/vs/${slug}`,
  keywords: [
    `quil vs ${slug}`,
    `${slug} alternative`,
    `${slug} comparison`,
    "terminal multiplexer comparison",
    "persistent terminal",
  ],
};

const schemas = [
  breadcrumbSchema([
    { name: "Quil", path: "/" },
    { name: "Compare", path: `/vs/${slug}` },
    { name: info.name, path: `/vs/${slug}` },
  ]),
  faqSchema(info.faq),
];

// The set of "also see" links — every competitor except the current one.
const otherCompetitors = (
  Object.keys(competitors) as CompetitorInfo["slug"][]
).filter((s) => s !== slug);

// Cell rendering helper: yes → green check, no → red x, partial → amber triangle.
const cellIcon = (s: Support): { name: "check" | "x" | "triangle-alert"; colour: string } => {
  if (s === "yes") return { name: "check", colour: "text-mint" };
  if (s === "no") return { name: "x", colour: "text-destructive/80" };
  return { name: "triangle-alert", colour: "text-warning" };
};
---
<Page {...seo} schemas={schemas}>
  <article class="mx-auto max-w-5xl px-6 py-16">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-6 flex items-center gap-2 text-sm text-muted-foreground">
      <a href="/" class="hover:text-foreground">Quil</a>
      <Icon name="chevron-right" size={14} />
      <span class="text-muted-foreground">Compare</span>
      <Icon name="chevron-right" size={14} />
      <span class="text-foreground">{info.name}</span>
    </nav>

    <!-- Hero -->
    <header class="mb-14">
      <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-sage">
        Compare
      </p>
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
        Quil <span class="text-sage">vs</span> {info.name}
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-muted-foreground">
        {info.description}
      </p>
    </header>

    <!-- Positioning -->
    <section class="mb-14">
      <div class="glass-card p-8">
        <div class="mb-3 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-sage">
          <Icon name="leaf" size={14} />
          Where they fit
        </div>
        <p class="text-base leading-relaxed text-foreground/90">
          {info.positioning}
        </p>
      </div>
    </section>

    <!-- Feature matrix -->
    <section class="mb-14">
      <h2 class="mb-6 text-2xl font-semibold tracking-tight">Feature matrix</h2>
      <div class="glass-card overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border/60 bg-muted/40">
              <th class="px-5 py-4 text-left text-xs font-semibold uppercase tracking-wider text-sage">
                Feature
              </th>
              <th class="px-5 py-4 text-center text-xs font-semibold uppercase tracking-wider text-mint">
                Quil
              </th>
              <th class="px-5 py-4 text-center text-xs font-semibold uppercase tracking-wider text-muted-foreground">
                {info.name}
              </th>
            </tr>
          </thead>
          <tbody>
            {competitorMatrix.map((row) => {
              const quilCell = cellIcon(row.quil);
              const otherCell = cellIcon(row[slug]);
              return (
                <>
                  <tr class="border-b border-border/40">
                    <td class="px-5 py-4 text-foreground/90">{row.feature}</td>
                    <td class="px-5 py-4 text-center">
                      <span class={`inline-flex size-8 items-center justify-center rounded-lg bg-primary/10 ring-1 ring-primary/30 ${quilCell.colour}`}>
                        <Icon name={quilCell.name} size={16} />
                      </span>
                    </td>
                    <td class="px-5 py-4 text-center">
                      <span class={`inline-flex size-8 items-center justify-center rounded-lg bg-muted/60 ring-1 ring-border ${otherCell.colour}`}>
                        <Icon name={otherCell.name} size={16} />
                      </span>
                    </td>
                  </tr>
                  {row.note && (
                    <tr class="border-b border-border/40">
                      <td colspan="3" class="px-5 pb-3 pt-0 text-xs italic text-sage">
                        {row.note}
                      </td>
                    </tr>
                  )}
                </>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Key strength / key gap -->
    <section class="mb-14 grid gap-6 md:grid-cols-2">
      <article class="glass-card p-6" style="border-color: hsl(var(--primary) / 0.35);">
        <div class="mb-3 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-mint">
          <Icon name="check" size={14} />
          Where {info.name} wins
        </div>
        <p class="text-sm leading-relaxed text-muted-foreground">
          {info.keyStrength}
        </p>
      </article>

      <article class="glass-card p-6" style="border-color: hsl(var(--warning) / 0.35);">
        <div class="mb-3 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-warning">
          <Icon name="triangle-alert" size={14} />
          Where {info.name} stops
        </div>
        <p class="text-sm leading-relaxed text-muted-foreground">
          {info.keyGap}
        </p>
      </article>
    </section>

    <!-- Migration note -->
    <section class="mb-14">
      <div class="glass-card p-8">
        <div class="mb-3 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-sage">
          <Icon name="arrow-right" size={14} />
          Coming from {info.name}?
        </div>
        <p class="text-sm leading-relaxed text-muted-foreground">
          {info.migrationNote}
        </p>
      </div>
    </section>

    <!-- FAQ -->
    <section class="mb-14">
      <h2 class="mb-6 text-2xl font-semibold tracking-tight">Common questions</h2>
      <div class="space-y-3">
        {info.faq.map((item) => (
          <details class="glass-card group overflow-hidden">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-5 text-left text-base font-semibold text-foreground [&::-webkit-details-marker]:hidden">
              <span>{item.question}</span>
              <Icon
                name="chevron-down"
                size={18}
                class="shrink-0 text-sage transition-transform group-open:rotate-180"
              />
            </summary>
            <div class="border-t border-border/60 px-5 py-4 text-sm leading-relaxed text-muted-foreground">
              {item.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- See also -->
    <section class="mb-14">
      <h2 class="mb-6 text-2xl font-semibold tracking-tight">See also</h2>
      <div class="grid gap-4 sm:grid-cols-3">
        {otherCompetitors.map((other) => (
          <a
            href={`/vs/${other}`}
            class="glass-card block p-5 transition-colors hover:border-primary/40"
          >
            <div class="text-xs font-semibold uppercase tracking-wider text-sage">
              Compare
            </div>
            <div class="mt-2 flex items-center justify-between">
              <span class="font-semibold text-foreground">Quil vs {competitors[other].name}</span>
              <Icon name="arrow-right" size={14} class="text-mint" />
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Final CTA -->
    <section>
      <div class="glass-card p-10 text-center">
        <h2 class="text-2xl font-semibold tracking-tight">
          Ready to try Quil?
        </h2>
        <p class="mx-auto mt-3 max-w-xl text-sm text-muted-foreground">
          Installation takes about 30 seconds. Your {info.name} setup
          stays untouched — Quil installs side-by-side.
        </p>
        <div class="mt-6 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href="/install" class="btn-primary">
            <Icon name="download" size={18} />
            Install Quil
          </a>
          <a href="/features" class="btn-outline">
            <Icon name="layers" size={16} />
            See every feature
          </a>
        </div>
      </div>
    </section>
  </article>
</Page>
