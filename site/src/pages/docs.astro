---
/**
 * Docs landing — GitHub is the canonical source of truth. This page
 * is a map: every tile opens the Markdown file in the repo.
 */
import Page from "@/layouts/Page.astro";
import { SITE } from "@/data/seo";
import { breadcrumbSchema, itemListSchema } from "@/data/schemas";

const seo = {
  title: "Documentation — VISION, PRD, architecture, plugin reference",
  description:
    "Every Quil document lives in the GitHub repo as plain Markdown. Vision, PRD, architecture decision records, roadmap, plugin authoring reference, contributing guide, and changelog.",
  path: "/docs",
  ogImage: "/og/docs.png",
  keywords: [
    "quil docs",
    "quil documentation",
    "quil architecture",
    "quil plugin reference",
    "quil vision",
  ],
};

interface DocEntry {
  name: string;
  path: string;
  desc: string;
  tag: string;
}

interface DocSection {
  title: string;
  items: DocEntry[];
}

const sections: DocSection[] = [
  {
    title: "Project context",
    items: [
      { name: "README",       path: "README.md",       tag: "← OVERVIEW",   desc: "Project overview, features, install instructions, and keybinding reference. Start here." },
      { name: "VISION",       path: "VISION.md",       tag: "← PHILOSOPHY", desc: "Why Quil exists, who it's for, and what problem the reboot-proof workspace promise solves." },
      { name: "PRD",          path: "PRD.md",          tag: "← SPEC",       desc: "Full product requirements: personas, user stories, success metrics, scope boundaries." },
      { name: "ARCHITECTURE", path: "ARCHITECTURE.md", tag: "← INTERNALS",  desc: "Client-daemon model, PTY backends, IPC protocol, state persistence, ADRs." },
      { name: "ROADMAP",      path: "ROADMAP.md",      tag: "← PLAN",       desc: "Milestone-by-milestone progress through M12, plus the in-flight M5 polish work." },
      { name: "CHANGELOG",    path: "CHANGELOG.md",    tag: "← HISTORY",    desc: "Keep-a-Changelog formatted history of every release from v0.1.0 onward." },
    ],
  },
  {
    title: "Authoring guides",
    items: [
      { name: "Plugin reference", path: "docs/plugin-reference.md", tag: "← PLUGINS",   desc: "Complete TOML plugin schema: [plugin], [command], [persistence], [[error_handlers]], and examples." },
      { name: "Contributing",     path: "CONTRIBUTING.md",          tag: "← CONTRIB",   desc: "How to set up the dev environment, run tests, and submit a pull request." },
      { name: "Versioning",       path: "VERSIONING.md",            tag: "← SEMVER",    desc: "Semantic versioning policy driven by Conventional Commits." },
    ],
  },
  {
    title: "Future roadmap PRDs",
    items: [
      { name: "Command palette",    path: "docs/roadmap/command-palette.md",    tag: "← FUTURE", desc: "Fuzzy-search command bar accessible via Ctrl+Shift+P. Future milestone." },
      { name: "Community plugins",  path: "docs/roadmap/community-plugins.md",  tag: "← FUTURE", desc: "A registry + discovery mechanism for user-contributed TOML plugins." },
      { name: "Session sharing",    path: "docs/roadmap/session-sharing.md",    tag: "← FUTURE", desc: "Read-only tunnel into a live Quil workspace so a collaborator can watch your panes." },
      { name: "Process health",     path: "docs/roadmap/process-health.md",     tag: "← FUTURE", desc: "Liveness probes per pane with automatic restart policies. Think systemd for pane processes." },
      { name: "Tmux migration",     path: "docs/roadmap/tmux-migration.md",     tag: "← FUTURE", desc: "Import tmux sessions — read ~/.tmux/resurrect/ and map them into Quil's workspace model." },
      { name: "Workspace files",    path: "docs/roadmap/workspace-files.md",    tag: "← FUTURE", desc: "Declarative workspace definitions in quil.toml checked into project repos." },
    ],
  },
];

const allDocItems = sections.flatMap((section) =>
  section.items.map((item) => ({
    name: item.name,
    description: item.desc,
    url: `${SITE.github}/blob/master/${item.path}`,
  })),
);

const schemas = [
  breadcrumbSchema([
    { name: "Quil",          path: "/" },
    { name: "Documentation", path: "/docs" },
  ]),
  itemListSchema({
    name: "Quil documentation",
    description:
      "All Quil project docs — vision, PRD, architecture, roadmap, plugin reference, contributing guide, and future-milestone PRDs.",
    url: SITE.url + "/docs",
    items: allDocItems,
  }),
];
---
<Page {...seo} schemas={schemas}>
  <section class="page-hero">
    <div class="container-ember stack">
      <div class="hero-ruler">
        <span>§ DOCS · ENTRY POINTS</span>
        <span style="margin-left:auto;">canonical source of truth: github</span>
      </div>
      <span class="eyebrow">DOCUMENTATION</span>
      <h1>Read the source.</h1>
      <p>
        Quil's docs live on GitHub next to the code — README, VISION,
        PRD, ARCHITECTURE, ROADMAP, plugin reference. This page is a
        map.
      </p>
    </div>
  </section>

  {sections.map((section, sectionIdx) => (
    <section class="feat-category">
      <div class="container-ember stack">
        <div class="feat-category-head">
          <div>
            <span class="eyebrow">§ {String(sectionIdx + 1).padStart(2, "0")} / {String(sections.length).padStart(2, "0")}</span>
            <h2 style="margin-top:10px;">{section.title}</h2>
          </div>
          <span class="count">{section.items.length} {section.items.length === 1 ? "DOC" : "DOCS"}</span>
        </div>

        <div class="feature-grid">
          {section.items.map((item) => (
            <a
              href={`${SITE.github}/blob/master/${item.path}`}
              rel="noopener external"
              class="feature-cell"
              style="text-decoration:none;"
            >
              <div class="feat-head">
                <span class="feat-num">↗</span>
                <span class="feat-title">{item.name}</span>
              </div>
              <p class="feat-body">{item.desc}</p>
              <span class="feat-tag">{item.tag}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="cta" style="padding: 80px 0;">
    <div class="container-ember stack">
      <div class="cta-inner">
        <h2 style="font-size: clamp(30px, 4vw, 52px);">
          Reading the source? <span class="flame-text">Start here.</span>
        </h2>
        <p>
          Daemon at <code>cmd/quild/</code>, TUI client at <code>cmd/quil/</code>,
          shared internals under <code>internal/</code>. Issues and PRs welcome.
        </p>
        <div class="actions">
          <a href={SITE.github} class="btn btn-primary" rel="noopener external">▸ browse repo</a>
          <a href={SITE.github + "/issues"} class="btn btn-outline" rel="noopener external">open an issue</a>
        </div>
      </div>
    </div>
  </section>
</Page>
