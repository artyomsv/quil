  function renderPane(key: string): void {
    const el = document.getElementById("pane-" + key + "-content");
    if (!el) return;
    el.innerHTML = "";
    const lines = PANE_CONTENT[key];
    let i = 0;
    const next = () => {
      if (i >= lines.length) return;
      const line = lines[i];
      const d = document.createElement("div");
      d.className = line.cls;
      d.innerHTML = line.html || "&nbsp;";
      d.style.opacity = "0";
      el.appendChild(d);
      requestAnimationFrame(() => {
        d.style.transition = "opacity 0.15s";
        d.style.opacity = "1";
      });
      i++;
      setTimeout(next, 160 + Math.random() * 90);
    };
    next();
  }

  (["claude", "shell", "ssh", "stripe"] as const).forEach((k, idx) => {
    setTimeout(() => renderPane(k), 200 + idx * 400);
  });

  const paneLabels: Record<string, string> = {
    claude: "1/4 · claude-code",
    shell: "2/4 · terminal",
    ssh: "3/4 · ssh",
    stripe: "4/4 · stripe",
  };

  document.querySelectorAll<HTMLElement>(".demo-pane").forEach((p) => {
    p.addEventListener("click", () => {
      document.querySelectorAll(".demo-pane").forEach((x) => x.classList.remove("focused"));
      p.classList.add("focused");
      const name = p.dataset.pane;
      const focusName = document.getElementById("focus-name");
      if (focusName && name) focusName.textContent = paneLabels[name] ?? name;
    });
  });

  document.querySelectorAll<HTMLElement>(".demo-tab").forEach((t) => {
    t.addEventListener("click", () => {
      document.querySelectorAll(".demo-tab").forEach((x) => x.classList.remove("active"));
      t.classList.add("active");
    });
  });

  // ------------------------------------------------------------------
  // Status bar — fake "snapshot N seconds ago" ticker
  // ------------------------------------------------------------------
  let snapSecs = 2;
  setInterval(() => {
    snapSecs = (snapSecs + 1) % 180;
    const el = document.getElementById("snap-time");
    if (!el) return;
    const mm = Math.floor(snapSecs / 60);
    const ss = snapSecs % 60;
    el.textContent = `00:0${mm}:${String(ss).padStart(2, "0")} ago`;
  }, 1000);

  // ------------------------------------------------------------------
  // Copy-install button
  // ------------------------------------------------------------------
  const copyBtn = document.getElementById("copy-install") as HTMLButtonElement | null;
  const installCmd = document.getElementById("install-cmd");
  if (copyBtn && installCmd && navigator.clipboard) {
    copyBtn.addEventListener("click", () => {
      navigator.clipboard.writeText(installCmd.textContent ?? "").then(() => {
        copyBtn.textContent = "COPIED";
        setTimeout(() => (copyBtn.textContent = "COPY"), 1500);
      });
    });
  }
</script>
