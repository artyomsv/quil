---
/**
 * Shared template for every /vs/<competitor>/ page. Each competitor
 * page is a thin stub that imports this component:
 *
 *   import ComparePage from "@/components/ComparePage.astro";
 *   <ComparePage slug="tmux" />
 *
 * All content lives in `src/data/competitors.ts` — one edit there
 * updates all four pages.
 */
import Page from "@/layouts/Page.astro";
import {
  competitorMatrix,
  competitors,
  type CompetitorInfo,
  type Support,
} from "@/data/competitors";
import { breadcrumbSchema, faqSchema } from "@/data/schemas";

interface Props {
  slug: CompetitorInfo["slug"];
}

const { slug } = Astro.props;
const info = competitors[slug];

const seo = {
  title: `Quil vs ${info.name}`,
  description: `How Quil compares to ${info.name}: side-by-side feature matrix, where each tool wins, and what ${info.name} can't do that Quil can. Reboot-proof persistence, AI session resume, typed panes, MCP server.`,
  path: `/vs/${slug}`,
  ogImage: `/og/vs-${slug}.png`,
  keywords: [
    `quil vs ${slug}`,
    `${slug} alternative`,
    `${slug} comparison`,
    "terminal multiplexer comparison",
    "persistent terminal",
  ],
};

const schemas = [
  breadcrumbSchema([
    { name: "Quil",   path: "/" },
    { name: "Compare", path: `/vs/${slug}` },
    { name: info.name, path: `/vs/${slug}` },
  ]),
  faqSchema(info.faq),
];

const otherCompetitors = (
  Object.keys(competitors) as CompetitorInfo["slug"][]
).filter((s) => s !== slug);

interface CellGlyph {
  label: string;
  klass: "yes" | "no" | "partial";
}

function cellGlyph(support: Support): CellGlyph {
  if (support === "yes") return { label: "✓", klass: "yes" };
  if (support === "no")  return { label: "✕", klass: "no"  };
  return { label: "~", klass: "partial" };
}
---
<Page {...seo} schemas={schemas}>
  <section class="page-hero">
    <div class="container-ember stack">
      <div class="hero-ruler">
        <span>§ COMPARE · VS {info.name.toUpperCase()}</span>
        <span>FEATURES <b>{competitorMatrix.length}</b></span>
        <span style="margin-left:auto;">← <a href="/" style="color:var(--ink-3);">all comparisons</a></span>
      </div>
      <span class="eyebrow">QUIL vs {info.name.toUpperCase()}</span>
      <h1>Quil <span class="flame-text">vs</span> {info.name}.</h1>
      <p>{info.description}</p>
    </div>
  </section>

  <!-- Where each tool fits -->
  <section style="padding: 72px 0; border-bottom: 1px solid var(--line);">
    <div class="container-ember stack">
      <div class="compare-grid">
        <div>
          <span class="eyebrow">{info.name.toUpperCase()} · WHERE IT WINS</span>
          <h2 class="h2" style="margin-top:14px; font-size:28px;">{info.keyStrength.split(".")[0]}.</h2>
          <p style="margin-top:18px; color:var(--ink-2);">{info.keyStrength}</p>
        </div>
        <div>
          <span class="eyebrow">QUIL · WHERE IT TAKES OVER</span>
          <h2 class="h2" style="margin-top:14px; font-size:28px;">Reboot survival. AI continuity. Typed panes.</h2>
          <p style="margin-top:18px; color:var(--ink-2);">{info.keyGap}</p>
        </div>
      </div>

      <div style="margin-top:48px; padding:24px; border:1px solid var(--line-2); background:var(--bg-2);">
        <div class="section-tag"><span class="dot"></span>WHERE THEY FIT</div>
        <p style="margin-top:14px; color:var(--ink-2); font-size:16px; line-height:1.7;">{info.positioning}</p>
      </div>
    </div>
  </section>

  <!-- Feature matrix -->
  <section style="padding: 72px 0; border-bottom: 1px solid var(--line);">
    <div class="container-ember stack">
      <span class="eyebrow">CAPABILITY MATRIX</span>
      <h2 class="h2" style="margin-top:10px;">Feature by feature.</h2>

      <table class="cmp-table">
        <thead>
          <tr>
            <th>capability</th>
            <th class="quil val">quil</th>
            <th class="val">{info.name}</th>
          </tr>
        </thead>
        <tbody>
          {competitorMatrix.map((row) => {
            const quilCell = cellGlyph(row.quil);
            const otherCell = cellGlyph(row[slug]);
            return (
              <>
                <tr>
                  <td class="feat">{row.feature}</td>
                  <td class="val"><b class={quilCell.klass}>{quilCell.label}</b></td>
                  <td class="val"><b class={otherCell.klass}>{otherCell.label}</b></td>
                </tr>
                {row.note && (
                  <tr>
                    <td colspan="3" style="padding-top:0; font-size:11.5px; color:var(--ink-4); font-style:italic;">
                      └── {row.note}
                    </td>
                  </tr>
                )}
              </>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Migration + FAQ -->
  <section style="padding: 72px 0; border-bottom: 1px solid var(--line);">
    <div class="container-narrow stack">
      <span class="eyebrow">MIGRATING FROM {info.name.toUpperCase()}</span>
      <h2 class="h2" style="margin-top:10px;">Coming from {info.name}?</h2>
      <p style="margin-top:18px; color:var(--ink-2); font-size:16px; line-height:1.7;">{info.migrationNote}</p>

      <div style="margin-top:32px; padding:24px; border:1px solid var(--line-2); background:var(--bg-2);">
        <div class="eyebrow" style="color:var(--flame);">FAQ</div>
        <div class="faq-list">
          {info.faq.map((item) => (
            <details class="faq-item">
              <summary>▸ {item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- See also -->
  <section style="padding: 72px 0; border-bottom: 1px solid var(--line);">
    <div class="container-ember stack">
      <span class="eyebrow">SEE ALSO</span>
      <h2 class="h2" style="margin-top:10px; font-size:28px;">Other comparisons.</h2>
      <div class="compare-tiles" style="margin-top:24px; grid-template-columns: repeat(3, 1fr);">
        {otherCompetitors.map((other) => (
          <a href={`/vs/${other}`} class="compare-tile">
            <span class="vs">vs ·</span>
            <span class="name">{competitors[other].name}</span>
            <span class="arrow">→ compare</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta" style="padding: 80px 0;">
    <div class="container-ember stack">
      <div class="cta-inner">
        <h2 style="font-size: clamp(32px, 4.5vw, 52px);">
          Try them both. <span class="flame-text">Pick a side.</span>
        </h2>
        <p>Quil installs side-by-side with {info.name}. Nothing to uninstall first.</p>
        <div class="actions">
          <a href="/install" class="btn btn-primary">▸ install quil</a>
          <a href="/features" class="btn btn-outline">every capability →</a>
        </div>
      </div>
    </div>
  </section>
</Page>

<style>
  .faq-list {
    margin-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .faq-item summary {
    cursor: pointer;
    font-family: var(--mono-stack);
    color: var(--ink);
    padding: 8px 0;
    list-style: none;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item[open] summary {
    color: var(--flame);
  }
  .faq-item p {
    padding: 10px 0 0 14px;
    color: var(--ink-2);
    font-size: 14px;
    line-height: 1.65;
  }
</style>
