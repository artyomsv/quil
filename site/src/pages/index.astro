---
import Page from "@/layouts/Page.astro";
import Icon from "@/components/Icon.astro";
import { SITE } from "@/data/seo";
import { softwareApplicationSchema, faqSchema } from "@/data/schemas";
import { homeFaq } from "@/data/faq";

const seo = {
  title: "The workspace that survives every reboot",
  description:
    "Quil is a reboot-proof terminal multiplexer for AI-native developers. Type `quil` after a restart and your tabs, panes, AI sessions, and running tools snap back in under 30 seconds.",
  path: "/",
  ogImage: "/og/home.png",
  keywords: [
    "quil",
    "terminal multiplexer",
    "persistent terminal",
    "tmux alternative",
    "ai terminal",
    "claude code multiplexer",
    "reboot-proof workflow",
  ],
};

// Keep structured data even though the visible FAQ block is removed —
// the home page still hosts the FAQPage schema for Google rich results.
const schemas = [softwareApplicationSchema(), faqSchema(homeFaq)];

// Four hand-picked feature statements for the numbered list.
// Deliberately shorter than the old 6-card grid — density is the enemy.
const topFeatures = [
  {
    number: "01",
    title: "Reboot-proof sessions",
    body: "Tabs, panes, working directories, and layout state are snapshotted continuously. Type quil after a restart and everything's back in under 30 seconds.",
  },
  {
    number: "02",
    title: "AI sessions resume automatically",
    body: "Claude Code conversations come back with their session ID intact. No copy-paste, no context rebuild, no re-explaining the task.",
  },
  {
    number: "03",
    title: "Typed panes, not just shells",
    body: "A Claude Code pane resumes differently than an SSH tunnel, which resumes differently than a webhook listener. Four plugins built in, yours in 30 lines of TOML.",
  },
  {
    number: "04",
    title: "Native on Linux, macOS, and Windows",
    body: "ConPTY on Windows, creack/pty on Unix. Zero WSL required. One static binary per platform, ~40 MB, no runtime dependencies.",
  },
];

const compareLinks = [
  { slug: "tmux",    label: "vs tmux" },
  { slug: "zellij",  label: "vs Zellij" },
  { slug: "wezterm", label: "vs WezTerm" },
  { slug: "screen",  label: "vs GNU Screen" },
];
---
<Page {...seo} schemas={schemas}>
  <!-- =================================================================
       HERO — left-aligned, asymmetric, mono headline
       ================================================================= -->
  <section class="scanlines relative overflow-hidden">
    <div class="mx-auto max-w-5xl px-6 pt-20 pb-20 sm:pt-28 sm:pb-28">
      <!-- Terminal-prompt-style status pill -->
      <div class="mb-8 inline-flex items-center gap-2">
        <span class="pill pill-primary">
          <span class="size-1 rounded-full bg-primary"></span>
          v{SITE.software.version} · MIT · Cross-platform
        </span>
      </div>

      <!--
        Hero headline in JetBrains Mono. Three short lines so the
        caesurae act like line breaks in a poem — forces the eye to
        pause between ideas.
      -->
      <h1 class="font-mono text-4xl font-bold leading-[1.05] tracking-tight text-foreground sm:text-6xl lg:text-7xl">
        <span class="block">The workspace</span>
        <span class="block">that <span class="gradient-flame">doesn't forget.</span></span>
      </h1>

      <p class="mt-8 max-w-2xl text-lg leading-relaxed text-muted-foreground sm:text-xl">
        Quil is a reboot-proof terminal multiplexer for developers who
        run complex multi-tool AI workflows. AI sessions, running
        processes, and your whole setup — back in 30 seconds after
        any restart.
      </p>

      <div class="mt-10 flex flex-col gap-3 sm:flex-row">
        <a href="/install" class="btn-primary">
          <Icon name="download" size={18} />
          Install in 30 seconds
          <Icon name="arrow-right" size={16} />
        </a>
        <a href={SITE.github} rel="noopener external" class="btn-outline">
          <Icon name="github" size={16} />
          View on GitHub
        </a>
      </div>
    </div>
  </section>

  <div class="divider-ember mx-auto max-w-5xl"></div>

  <!-- =================================================================
       NUMBERED FEATURE LIST — single column, sparse, matte-black blocks
       ================================================================= -->
  <section class="mx-auto max-w-5xl px-6 pt-20 pb-16">
    <div class="mb-12 max-w-2xl">
      <p class="prompt mb-3 font-mono text-xs font-bold uppercase tracking-[0.2em] text-primary">
        what quil does
      </p>
      <h2 class="font-mono text-3xl font-bold tracking-tight sm:text-4xl">
        Four things. Done well.
      </h2>
    </div>

    <ol class="space-y-4">
      {topFeatures.map((f) => (
        <li class="feature-block">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-baseline sm:gap-6">
            <span class="shrink-0 font-mono text-sm font-bold text-primary">
              {f.number}
            </span>
            <div>
              <h3 class="font-mono text-lg font-semibold text-foreground sm:text-xl">
                {f.title}
              </h3>
              <p class="mt-2 max-w-3xl text-sm leading-relaxed text-muted-foreground sm:text-base">
                {f.body}
              </p>
            </div>
          </div>
        </li>
      ))}
    </ol>

    <div class="mt-8">
      <a
        href="/features"
        class="inline-flex items-center gap-2 font-mono text-sm font-medium text-primary hover:text-foreground"
      >
        <span class="prompt">see every capability</span>
        <Icon name="arrow-right" size={14} />
      </a>
    </div>
  </section>

  <div class="divider-ember mx-auto max-w-5xl"></div>

  <!-- =================================================================
       COMPARE TEASER — single line + four small pills
       ================================================================= -->
  <section class="mx-auto max-w-5xl px-6 py-16">
    <div class="max-w-3xl">
      <p class="prompt mb-3 font-mono text-xs font-bold uppercase tracking-[0.2em] text-primary">
        how it compares
      </p>
      <h2 class="font-mono text-3xl font-bold tracking-tight sm:text-4xl">
        Not another tmux.
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-muted-foreground">
        tmux and Zellij survive network disconnects but not host reboots.
        WezTerm is a terminal emulator that happens to multiplex. Screen
        is 38 years old. Quil is a different category: a workflow
        orchestrator that treats your terminal as the source of truth.
      </p>
    </div>
    <div class="mt-8 flex flex-wrap gap-3">
      {compareLinks.map((c) => (
        <a
          href={`/vs/${c.slug}`}
          class="pill transition-colors hover:border-primary/60 hover:text-primary"
        >
          {c.label}
          <Icon name="arrow-right" size={12} />
        </a>
      ))}
    </div>
  </section>

  <div class="divider-ember mx-auto max-w-5xl"></div>

  <!-- =================================================================
       FINAL CTA — big, confident, no glass card
       ================================================================= -->
  <section class="mx-auto max-w-5xl px-6 pt-20 pb-28">
    <div class="max-w-3xl">
      <p class="prompt mb-3 font-mono text-xs font-bold uppercase tracking-[0.2em] text-primary">
        stop paying the reboot tax
      </p>
      <h2 class="font-mono text-3xl font-bold leading-tight tracking-tight sm:text-5xl">
        <span class="gradient-flame">Install it. Reboot once. Feel the difference.</span>
      </h2>
      <p class="mt-6 text-lg text-muted-foreground">
        One binary. No daemon to configure. No database to provision.
        No cloud account. Open source under MIT.
      </p>
      <div class="mt-10 flex flex-col gap-3 sm:flex-row">
        <a href="/install" class="btn-primary">
          <Icon name="download" size={18} />
          Install Quil
          <Icon name="arrow-right" size={16} />
        </a>
        <a href={SITE.github} rel="noopener external" class="btn-outline">
          <Icon name="github" size={16} />
          Star on GitHub
        </a>
      </div>
    </div>
  </section>
</Page>
